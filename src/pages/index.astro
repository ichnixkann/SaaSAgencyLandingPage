---
import "@/styles/global.css";
import Icon from "@/components/Icon.astro";
import { agency, stats, capabilities, steps, plans } from "@/data/agency";

const title = `${agency.name} — ${agency.kicker}`;
const description = agency.subline;
const consultation = capabilities.filter((c) => c.group === "Consultation");
const development = capabilities.filter((c) => c.group === "Development");
const trustedBy = ["Northwind", "Lumen", "Cohort", "Basecase", "Forma"];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        name: agency.name,
        description: agency.subline,
        email: agency.email,
        serviceType: "SaaS consultation and software development",
      })}
    />

    <style>
      :root {
        --font-grotesk: "Space Grotesk", ui-sans-serif, system-ui, sans-serif;
      }
      .font-grotesk {
        font-family: var(--font-grotesk);
      }
      body {
        font-family: "Inter", ui-sans-serif, system-ui, sans-serif;
      }
      @media (prefers-reduced-motion: reduce) {
        * {
          animation-duration: 0.001ms !important;
          transition-duration: 0.001ms !important;
        }
      }
    </style>
  </head>

  <body class="min-h-screen bg-zinc-950 text-zinc-100 antialiased">
    <a
      href="#main"
      class="sr-only rounded-lg bg-indigo-500 px-4 py-2 text-white focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50"
      >Skip to content</a
    >

    <!-- Ambient background: gradient glow + grid -->
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
      <div
        class="absolute -top-40 left-1/2 size-[44rem] -translate-x-1/2 rounded-full bg-indigo-600/20 blur-[120px]"
      >
      </div>
      <div
        class="absolute -right-40 top-1/3 size-[32rem] rounded-full bg-violet-600/15 blur-[120px]"
      >
      </div>
      <div
        class="absolute inset-0 opacity-[0.04]"
        style="background-image:linear-gradient(#fff 1px,transparent 1px),linear-gradient(90deg,#fff 1px,transparent 1px);background-size:56px 56px;"
      >
      </div>
    </div>

    <!-- Header -->
    <header
      id="top"
      class="sticky top-0 z-40 border-b border-white/5 bg-zinc-950/70 backdrop-blur-xl"
    >
      <div
        class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-5 py-3.5"
      >
        <a href="#top" class="flex items-center gap-2.5">
          <span
            class="grid size-8 place-items-center rounded-lg bg-gradient-to-br from-indigo-400 to-violet-500 font-grotesk text-sm font-700 text-zinc-950"
            >N</span
          >
          <span class="font-grotesk text-lg font-600">{agency.name}</span>
        </a>
        <nav
          aria-label="Main navigation"
          class="hidden items-center gap-8 text-sm text-zinc-400 md:flex"
        >
          <a href="#capabilities" class="transition-colors hover:text-white"
            >Capabilities</a
          >
          <a href="#process" class="transition-colors hover:text-white">Process</a>
          <a href="#pricing" class="transition-colors hover:text-white">Pricing</a>
        </nav>
        <a
          href={agency.emailHref}
          class="rounded-full bg-white px-4 py-2 text-sm font-600 text-zinc-950 transition-transform hover:-translate-y-0.5"
          >{agency.calendlyLabel}</a
        >
      </div>
    </header>

    <main id="main">
      <!-- Hero -->
      <section class="mx-auto max-w-6xl px-5 pb-20 pt-20 md:pt-28">
        <div
          class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-500 text-zinc-300"
        >
          <span class="size-1.5 rounded-full bg-indigo-400"></span>
          {agency.kicker}
        </div>

        <h1
          class="mt-6 max-w-4xl font-grotesk text-[clamp(2.5rem,1rem+6vw,5.25rem)] font-700 leading-[1.02] tracking-tight"
        >
          We design, build, and
          <span
            class="bg-gradient-to-r from-indigo-300 via-indigo-400 to-violet-400 bg-clip-text text-transparent"
            >scale SaaS products.</span
          >
        </h1>

        <p class="mt-6 max-w-xl text-lg text-zinc-400">{agency.subline}</p>

        <div class="mt-9 flex flex-wrap items-center gap-3">
          <a
            href={agency.emailHref}
            class="group inline-flex items-center gap-2 rounded-full bg-indigo-500 px-6 py-3 font-600 text-white shadow-lg shadow-indigo-500/25 transition-transform hover:-translate-y-0.5"
          >
            {agency.calendlyLabel}
            <Icon
              name="arrow"
              class="size-4 transition-transform group-hover:translate-x-0.5"
            />
          </a>
          <a
            href="#capabilities"
            class="rounded-full border border-white/15 px-6 py-3 font-500 text-zinc-200 transition-colors hover:bg-white/5"
            >See what we do</a
          >
        </div>

        <!-- Stats -->
        <dl
          class="mt-16 grid grid-cols-2 gap-px overflow-hidden rounded-2xl border border-white/10 bg-white/5 sm:grid-cols-4"
        >
          {
            stats.map((s) => (
              <div class="bg-zinc-950/40 p-6">
                <dt class="font-grotesk text-3xl font-700 text-white">
                  {s.value}
                </dt>
                <dd class="mt-1 text-sm text-zinc-400">{s.label}</dd>
              </div>
            ))
          }
        </dl>

        <!-- Trusted by -->
        <div class="mt-12 flex flex-wrap items-center gap-x-8 gap-y-3">
          <span class="text-xs uppercase tracking-widest text-zinc-500"
            >Trusted by teams at</span
          >
          {
            trustedBy.map((logo) => (
              <span class="font-grotesk text-sm font-600 text-zinc-500">
                {logo}
              </span>
            ))
          }
        </div>
      </section>

      <!-- Capabilities -->
      <section id="capabilities" class="mx-auto max-w-6xl px-5 py-20">
        <div class="max-w-2xl">
          <p class="text-sm font-600 uppercase tracking-widest text-indigo-400">
            Capabilities
          </p>
          <h2
            class="mt-3 font-grotesk text-[clamp(1.9rem,1rem+3vw,3rem)] font-600 leading-tight"
          >
            Two ways we move you forward
          </h2>
          <p class="mt-4 text-zinc-400">
            Strategy when you need clarity. Engineering when you need to ship.
            Usually both.
          </p>
        </div>

        <div class="mt-12 grid gap-10 lg:grid-cols-2">
          {
            [
              { label: "Consultation", items: consultation },
              { label: "Development", items: development },
            ].map((col) => (
              <div>
                <h3 class="mb-5 flex items-center gap-2 font-grotesk text-sm font-600 uppercase tracking-widest text-zinc-400">
                  <span class="h-px w-6 bg-gradient-to-r from-indigo-400 to-transparent" />
                  {col.label}
                </h3>
                <div class="grid gap-4">
                  {col.items.map((c) => (
                    <article class="group rounded-2xl border border-white/10 bg-white/[0.03] p-6 transition-colors hover:border-indigo-400/40 hover:bg-white/[0.06]">
                      <span class="grid size-11 place-items-center rounded-xl bg-indigo-500/10 text-indigo-300 ring-1 ring-inset ring-indigo-400/20 transition-colors group-hover:bg-indigo-500 group-hover:text-white">
                        <Icon name={c.icon} class="size-5" />
                      </span>
                      <h4 class="mt-4 font-grotesk text-lg font-600">
                        {c.title}
                      </h4>
                      <p class="mt-2 text-sm leading-relaxed text-zinc-400">
                        {c.description}
                      </p>
                    </article>
                  ))}
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <!-- Process -->
      <section
        id="process"
        class="border-y border-white/5 bg-white/[0.02]"
      >
        <div class="mx-auto max-w-6xl px-5 py-20">
          <div class="max-w-2xl">
            <p class="text-sm font-600 uppercase tracking-widest text-indigo-400">
              Process
            </p>
            <h2
              class="mt-3 font-grotesk text-[clamp(1.9rem,1rem+3vw,3rem)] font-600 leading-tight"
            >
              No black boxes. Demos every Friday.
            </h2>
          </div>

          <ol class="mt-12 grid gap-8 md:grid-cols-4">
            {
              steps.map((step) => (
                <li class="relative">
                  <span class="font-grotesk text-sm font-700 text-indigo-400">
                    {step.no}
                  </span>
                  <h3 class="mt-2 font-grotesk text-xl font-600">
                    {step.title}
                  </h3>
                  <p class="mt-2 text-sm text-zinc-400">{step.description}</p>
                </li>
              ))
            }
          </ol>
        </div>
      </section>

      <!-- Pricing -->
      <section id="pricing" class="mx-auto max-w-6xl px-5 py-20">
        <div class="max-w-2xl">
          <p class="text-sm font-600 uppercase tracking-widest text-indigo-400">
            Engagements
          </p>
          <h2
            class="mt-3 font-grotesk text-[clamp(1.9rem,1rem+3vw,3rem)] font-600 leading-tight"
          >
            Pick the entry point that fits
          </h2>
        </div>

        <div class="mt-12 grid gap-5 lg:grid-cols-3">
          {
            plans.map((plan) => (
              <article
                class:list={[
                  "relative flex flex-col rounded-2xl border p-7",
                  plan.featured
                    ? "border-indigo-400/50 bg-gradient-to-b from-indigo-500/15 to-white/[0.03] shadow-xl shadow-indigo-500/10"
                    : "border-white/10 bg-white/[0.03]",
                ]}
              >
                {plan.featured && (
                  <span class="absolute -top-3 left-7 rounded-full bg-indigo-500 px-3 py-1 text-xs font-600 text-white">
                    Most popular
                  </span>
                )}
                <h3 class="font-grotesk text-lg font-600">{plan.name}</h3>
                <p class="mt-1 text-sm text-zinc-400">{plan.blurb}</p>
                <div class="mt-5 flex items-baseline gap-2">
                  <span class="font-grotesk text-3xl font-700">
                    {plan.price}
                  </span>
                  <span class="text-sm text-zinc-500">{plan.cadence}</span>
                </div>
                <ul class="mt-6 grid gap-3 text-sm">
                  {plan.features.map((f) => (
                    <li class="flex items-start gap-2.5 text-zinc-300">
                      <Icon
                        name="check"
                        class="mt-0.5 size-4 shrink-0 text-indigo-400"
                      />
                      {f}
                    </li>
                  ))}
                </ul>
                <a
                  href={agency.emailHref}
                  class:list={[
                    "mt-7 rounded-full px-5 py-2.5 text-center font-600 transition-transform hover:-translate-y-0.5",
                    plan.featured
                      ? "bg-indigo-500 text-white shadow-lg shadow-indigo-500/25"
                      : "border border-white/15 text-zinc-100 hover:bg-white/5",
                  ]}
                >
                  Get started
                </a>
              </article>
            ))
          }
        </div>
      </section>

      <!-- CTA -->
      <section class="mx-auto max-w-6xl px-5 pb-24">
        <div
          class="relative overflow-hidden rounded-3xl border border-white/10 bg-gradient-to-br from-indigo-600/30 via-zinc-900 to-violet-700/20 p-10 text-center md:p-16"
        >
          <h2
            class="font-grotesk text-[clamp(2rem,1rem+4vw,3.5rem)] font-700 leading-tight"
          >
            Have a product to build?
          </h2>
          <p class="mx-auto mt-4 max-w-md text-zinc-300">
            Tell us what you're working on. We'll come back with a plan, a
            timeline, and a number — usually within a day.
          </p>
          <div class="mt-8 flex flex-wrap justify-center gap-3">
            <a
              href={agency.emailHref}
              class="rounded-full bg-white px-6 py-3 font-600 text-zinc-950 transition-transform hover:-translate-y-0.5"
              >{agency.calendlyLabel}</a
            >
            <a
              href={agency.emailHref}
              class="rounded-full border border-white/20 px-6 py-3 font-500 text-white transition-colors hover:bg-white/10"
              >{agency.email}</a
            >
          </div>
        </div>
      </section>
    </main>

    <footer class="border-t border-white/5">
      <div
        class="mx-auto flex max-w-6xl flex-col gap-4 px-5 py-8 text-sm text-zinc-500 sm:flex-row sm:items-center sm:justify-between"
      >
        <p>© {new Date().getFullYear()} {agency.name} · {agency.kicker}</p>
        <nav aria-label="Footer" class="flex gap-6">
          <a href="#capabilities" class="transition-colors hover:text-zinc-300">Capabilities</a>
          <a href="#" class="transition-colors hover:text-zinc-300">Privacy</a>
          <a href="#" class="transition-colors hover:text-zinc-300">Imprint</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
